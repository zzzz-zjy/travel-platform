generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Continent {
  id            Int       @id @default(autoincrement())
  name          String    @unique
  boundsGeojson String    @map("bounds_geojson")
  countries     Country[]
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@map("continents")
}

model Country {
  id          Int       @id @default(autoincrement())
  continentId Int       @map("continent_id")
  name        String    @unique
  slug        String    @unique
  flagUrl     String?   @map("flag_url")
  geojson     String?
  continent   Continent @relation(fields: [continentId], references: [id])
  provinces   Province[]
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("countries")
}

model Province {
  id        Int       @id @default(autoincrement())
  countryId Int       @map("country_id")
  name      String
  geojson   String?
  country   Country   @relation(fields: [countryId], references: [id])
  cities    City[]
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@map("provinces")
}

model City {
  id          Int          @id @default(autoincrement())
  provinceId  Int          @map("province_id")
  name        String
  lat         Float
  lng         Float
  province    Province     @relation(fields: [provinceId], references: [id])
  attractions Attraction[]
  guides      Guide[]
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  @@map("cities")
}

model Attraction {
  id            Int        @id @default(autoincrement())
  cityId        Int        @map("city_id")
  name          String
  category      String
  lat           Float
  lng           Float
  rating        Float      @default(4.0)
  images        String     @default("[]")
  ticketInfo    String?    @map("ticket_info")
  transportTips String?    @map("transport_tips")
  description   String?
  city          City       @relation(fields: [cityId], references: [id])
  guideItems    GuideItem[]
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  @@map("attractions")
}

model Guide {
  id                Int        @id @default(autoincrement())
  title             String
  destinationCityId Int        @map("destination_city_id")
  totalDays         Int        @map("total_days")
  budgetAmount      Int        @map("budget_amount")
  transportMode     String     @map("transport_mode")
  travelStyle       String     @map("travel_style")
  rawJson           String?    @map("raw_json")
  destinationCity   City       @relation(fields: [destinationCityId], references: [id])
  days              GuideDay[]
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")

  @@map("guides")
}

model GuideDay {
  id        Int         @id @default(autoincrement())
  guideId   Int         @map("guide_id")
  dayNumber Int         @map("day_number")
  title     String
  notes     String?
  guide     Guide       @relation(fields: [guideId], references: [id])
  items     GuideItem[]
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  @@map("guide_days")
}

model GuideItem {
  id             Int         @id @default(autoincrement())
  guideDayId     Int         @map("guide_day_id")
  attractionId   Int?        @map("attraction_id")
  timeSlot       String      @map("time_slot")
  customSpot     String?     @map("custom_spot")
  durationMin    Int         @map("duration_min")
  ticketReminder String?     @map("ticket_reminder")
  tips           String?
  guideDay       GuideDay    @relation(fields: [guideDayId], references: [id])
  attraction     Attraction? @relation(fields: [attractionId], references: [id])
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  @@map("guide_items")
}
